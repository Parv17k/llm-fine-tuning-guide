   "source": [
    "# Appendices - Interactive Reference\n",
    "\n",
    "Hands-on reference tools for Module 11, covering:\n",
    "\n",
    "1. Interactive glossary search\n",
    "2. Troubleshooting decision tree\n",
    "3. Dataset selector by domain\n",
    "4. Model comparison tool\n",
    "5. Configuration generator"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Interactive Glossary"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Comprehensive glossary database\n",
    "GLOSSARY = {\n",
    "    \"LoRA\": \"Low-Rank Adaptation - Parameter-efficient fine-tuning method using low-rank matrices\",\n",
    "    \"QLoRA\": \"Quantized LoRA - 4-bit quantized LoRA for memory-efficient training\",\n",
    "    \"DPO\": \"Direct Preference Optimization - RLHF alternative optimizing directly on preferences\",\n",
    "    \"ORPO\": \"Odds Ratio Preference Optimization - Simplified DPO without reference model\",\n",
    "    \"SFT\": \"Supervised Fine-Tuning - Standard fine-tuning on labeled data\",\n",
    "    \"RLHF\": \"Reinforcement Learning from Human Feedback - Alignment using reward models\",\n",
    "    \"PEFT\": \"Parameter-Efficient Fine-Tuning - Methods like LoRA that train fewer parameters\",\n",
    "    \"GGUF\": \"GGML Unified Format - CPU-optimized model format for llama.cpp\",\n",
    "    \"AWQ\": \"Activation-aware Weight Quantization - GPU-friendly 4-bit quantization\",\n",
    "    \"VRAM\": \"Video RAM - GPU memory for model weights and activations\",\n",
    "    \"Batch Size\": \"Number of samples processed before gradient update\",\n",
    "    \"Gradient Accumulation\": \"Accumulating gradients over multiple batches to simulate larger batch\",\n",
    "    \"Learning Rate\": \"Step size for parameter updates during optimization\",\n",
    "    \"Perplexity\": \"Exponential of cross-entropy loss, lower is better\",\n",
    "    \"Tokenizer\": \"Converts text to token IDs and vice versa\",\n",
    "    \"Attention Mask\": \"Binary tensor indicating which tokens to attend to\",\n",
    "    \"Gradient Checkpointing\": \"Memory optimization trading compute for memory\",\n",
    "    \"ZeRO\": \"Zero Redundancy Optimizer - DeepSpeed memory optimization\",\n",
    "    \"DDP\": \"Distributed Data Parallel - Multi-GPU training with synchronized gradients\",\n",
    "    \"Overfitting\": \"Model memorizes training data, fails to generalize\",\n",
    "    \"Catastrophic Forgetting\": \"Model loses pre-trained knowledge during fine-tuning\",\n",
    "    \"Alignment\": \"Steering model behavior toward human preferences\",\n",
    "    \"RAG\": \"Retrieval-Augmented Generation - Using external knowledge with LLMs\",\n",
    "    \"CoT\": \"Chain-of-Thought - Prompting for step-by-step reasoning\",\n",
    "    \"Temperature\": \"Sampling parameter controlling randomness (higher = more random)\",\n",
    "    \"Top-p\": \"Nucleus sampling - probability mass threshold for token selection\",\n",
    "    \"Beam Search\": \"Decoding strategy exploring multiple hypotheses\",\n",
    "    \"NF4\": \"NormalFloat 4-bit - Quantization format optimized for neural weights\",\n",
    "    \"MMLU\": \"Massive Multitask Language Understanding - Knowledge benchmark\",\n",
    "    \"ROUGE\": \"Recall-Oriented Understudy for Gisting Evaluation - Summarization metric\",\n",
    "}\n",
    "\n",
    "def search_glossary(query: str) -> list:\n",
    "    \"\"\"Search glossary by keyword.\"\"\"\n",
    "    query = query.lower()\n",
    "    results = []\n",
    "    \n",
    "    for term, definition in GLOSSARY.items():\n",
    "        if query in term.lower() or query in definition.lower():\n",
    "            results.append((term, definition))\n",
    "    \n",
    "    return results\n",
    "\n",
    "# Demo glossary search\n",
    "print(\"Glossary Search Demo\")\n",
    "print(\"=\" * 60)\n",
    "\n",
    "search_terms = [\"lora\", \"quant\", \"attention\", \"optim\"]\n",
    "\n",
    "for term in search_terms:\n",
    "    results = search_glossary(term)\n",
    "    print(f\"\\nSearch: '{term}' -> {len(results)} results\")\n",
    "    for t, d in results[:3]:  # Show top 3\n",
    "        print(f\"  • {t}: {d[:60]}...\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Glossary quiz for learning\n",
    "import random\n",
    "\n",
    "def glossary_quiz(num_questions: int = 5):\n",
    "    \"\"\"Generate quiz from glossary terms.\"\"\"\n",
    "    terms = list(GLOSSARY.keys())\n",
    "    score = 0\n",
    "    \n",
    "    print(\"\\n\" + \"=\" * 60)\n",
    "    print(\"GLOSSARY QUIZ\")\n",
    "    print(\"=\" * 60)\n",
    "    \n",
    "    for i in range(num_questions):\n",
    "        correct_term = random.choice(terms)\n",
    "        correct_def = GLOSSARY[correct_term]\n",
    "        \n",
    "        # Generate wrong options\n",
    "        wrong_terms = random.sample([t for t in terms if t != correct_term], 3)\n",
    "        options = [correct_term] + wrong_terms\n",
    "        random.shuffle(options)\n",
    "        \n",
    "        print(f\"\\nQuestion {i+1}: What does this define?\")\n",
    "        print(f\"\\\"{correct_def}\\\"\")\n",
    "        print(\"\\nOptions:\")\n",
    "        for j, opt in enumerate(options):\n",
    "            print(f\"  {chr(65+j)}. {opt}\")\n",
    "        \n",
    "        # For demo, show answer\n",
    "        print(f\"\\nAnswer: {correct_term}\")\n",
    "    \n",
    "    print(\"\\n\" + \"=\" * 60)\n",
    "\n",
    "glossary_quiz(3)"
   ]
  },
