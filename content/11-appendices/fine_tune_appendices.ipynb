   "source": [
    "## 3. Dataset Selector"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Dataset catalog\n",
    "DATASETS = {\n",
    "    \"general\": [\n",
    "        {\"name\": \"Alpaca\", \"size\": \"52K\", \"license\": \"CC BY-NC\", \"quality\": 3, \"hf_id\": \"tatsu-lab/alpaca\"},\n",
    "        {\"name\": \"Dolly\", \"size\": \"15K\", \"license\": \"CC BY-SA\", \"quality\": 4, \"hf_id\": \"databricks/databricks-dolly-15k\"},\n",
    "        {\"name\": \"OpenOrca\", \"size\": \"1M+\", \"license\": \"Apache 2.0\", \"quality\": 4, \"hf_id\": \"Open-Orca/OpenOrca\"},\n",
    "        {\"name\": \"UltraChat\", \"size\": \"1.5M\", \"license\": \"Apache 2.0\", \"quality\": 5, \"hf_id\": \"HuggingFaceH4/ultrachat_200k\"},\n",
    "    ],\n",
    "    \"code\": [\n",
    "        {\"name\": \"CodeAlpaca\", \"size\": \"20K\", \"license\": \"CC BY-SA\", \"quality\": 3, \"hf_id\": \"sahil2801/CodeAlpaca-20k\"},\n",
    "        {\"name\": \"Evol-Instruct-Code\", \"size\": \"140K\", \"license\": \"MIT\", \"quality\": 4, \"hf_id\": \"WizardLM/WizardLM_evol_instruct_V2_143k\"},\n",
    "        {\"name\": \"The-Code-Alpaca\", \"size\": \"21K\", \"license\": \"Apache 2.0\", \"quality\": 4, \"hf_id\": \"sahil2801/The-Code-Alpaca\"},\n",
    "    ],\n",
    "    \"math\": [\n",
    "        {\"name\": \"GSM8K\", \"size\": \"8.5K\", \"license\": \"MIT\", \"quality\": 5, \"hf_id\": \"openai/gsm8k\"},\n",
    "        {\"name\": \"MathQA\", \"size\": \"37K\", \"license\": \"Apache 2.0\", \"quality\": 4, \"hf_id\": \"google-research-datasets/mathqa\"},\n",
    "        {\"name\": \"MATH\", \"size\": \"12K\", \"license\": \"MIT\", \"quality\": 5, \"hf_id\": \"hendrycks/competition_math\"},\n",
    "    ],\n",
    "    \"medical\": [\n",
    "        {\"name\": \"MedQA\", \"size\": \"10K\", \"license\": \"MIT\", \"quality\": 4, \"hf_id\": \"bigbio/med_qa\"},\n",
    "        {\"name\": \"HealthCareMagic\", \"size\": \"100K\", \"license\": \"CC BY-NC\", \"quality\": 3, \"hf_id\": \"UCSD/Medical-Chat\"},\n",
    "        {\"name\": \"PubMedQA\", \"size\": \"211K\", \"license\": \"MIT\", \"quality\": 4, \"hf_id\": \"bigbio/pubmed_qa\"},\n",
    "    ],\n",
    "    \"legal\": [\n",
    "        {\"name\": \"LawInstruct\", \"size\": \"50K\", \"license\": \"MIT\", \"quality\": 3, \"hf_id\": \"law-instruct/law-instruct\"},\n",
    "        {\"name\": \"Legal-Chatbot\", \"size\": \"12K\", \"license\": \"MIT\", \"quality\": 3, \"hf_id\": \"law-ai/legal-chatbot\"},\n",
    "    ],\n",
    "}\n",
    "\n",
    "def recommend_datasets(domain: str, min_quality: int = 3, max_size: str = None) -> list:\n",
    "    \"\"\"Recommend datasets for a domain.\"\"\"\n",
    "    domain = domain.lower()\n",
    "    \n",
    "    # Find matching domain\n",
    "    matching_domain = None\n",
    "    for d in DATASETS.keys():\n",
    "        if d in domain:\n",
    "            matching_domain = d\n",
    "            break\n",
    "    \n",
    "    if not matching_domain:\n",
    "        return DATASETS.get(\"general\", [])\n",
    "    \n",
    "    # Filter by quality\n",
    "    datasets = DATASETS[matching_domain]\n",
    "    filtered = [d for d in datasets if d[\"quality\"] >= min_quality]\n",
    "    \n",
    "    # Sort by quality (descending)\n",
    "    filtered.sort(key=lambda x: x[\"quality\"], reverse=True)\n",
    "    \n",
    "    return filtered\n",
    "\n",
    "# Demo dataset recommendation\n",
    "print(\"Dataset Recommendation Tool\")\n",
    "print(\"=\" * 60)\n",
    "\n",
    "test_domains = [\"code generation\", \"medical qa\", \"math\", \"legal\", \"chatbot\"]\n",
    "\n",
    "for domain in test_domains:\n",
    "    print(f\"\\nDomain: {domain}\")\n",
    "    recs = recommend_datasets(domain)\n",
    "    for ds in recs[:3]:\n",
    "        stars = \"⭐\" * ds[\"quality\"]\n",
    "        print(f\"  • {ds['name']} ({ds['size']}) - {ds['license']} - {stars}\")"
   ]
  },
