    "## 5. Configuration Generator"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def generate_training_config(\n",
    "    model_size: str = \"7b\",\n",
    "    vram_gb: float = 16,\n",
    "    method: str = \"lora\",\n",
    "    task: str = \"instruction\",\n",
    ") -> dict:\n",
    "    \"\"\"Generate training configuration based on constraints.\"\"\"\n",
    "    \n",
    "    # Base configurations by method\n",
    "    configs = {\n",
    "        \"full\": {\n",
    "            \"learning_rate\": 2e-5,\n",
    "            \"per_device_train_batch_size\": max(1, int(vram_gb / 8) - 2),\n",
    "            \"gradient_accumulation_steps\": 4,\n",
    "            \"gradient_checkpointing\": True,\n",
    "            \"bf16\": True,\n",
    "        },\n",
    "        \"lora\": {\n",
    "            \"learning_rate\": 2e-4,\n",
    "            \"per_device_train_batch_size\": max(2, int(vram_gb / 4)),\n",
    "            \"gradient_accumulation_steps\": 4,\n",
    "            \"lora_r\": 16,\n",
    "            \"lora_alpha\": 32,\n",
    "            \"lora_dropout\": 0.05,\n",
    "        },\n",
    "        \"qlora\": {\n",
    "            \"learning_rate\": 2e-4,\n",
    "            \"per_device_train_batch_size\": max(4, int(vram_gb / 2)),\n",
    "            \"gradient_accumulation_steps\": 8,\n",
    "            \"lora_r\": 32,\n",
    "            \"lora_alpha\": 64,\n",
    "            \"load_in_4bit\": True,\n",
    "            \"bnb_4bit_quant_type\": \"nf4\",\n",
    "        },\n",
    "    }\n",
    "    \n",
    "    base_config = configs.get(method, configs[\"lora\"])\n",
    "    \n",
    "    # Adjust for model size\n",
    "    size_multipliers = {\"1b\": 0.5, \"3b\": 0.7, \"7b\": 1.0, \"13b\": 1.5, \"70b\": 3.0}\n",
    "    multiplier = size_multipliers.get(model_size.lower(), 1.0)\n",
    "    \n",
    "    # Adjust batch size for model size\n",
    "    base_config[\"per_device_train_batch_size\"] = max(\n",
    "        1,\n",
    "        int(base_config[\"per_device_train_batch_size\"] / multiplier)\n",
    "    )\n",
    "    \n",
    "    # Add task-specific settings\n",
    "    if task == \"instruction\":\n",
    "        base_config[\"num_train_epochs\"] = 3\n",
    "    elif task == \"chat\":\n",
    "        base_config[\"num_train_epochs\"] = 2\n",
    "    elif task == \"code\":\n",
    "        base_config[\"num_train_epochs\"] = 5\n",
    "    \n",
    "    return {\n",
    "        \"model\": f\"model-{model_size}\",\n",
    "        \"method\": method,\n",
    "        \"vram_gb\": vram_gb,\n",
    "        **base_config,\n",
    "    }\n",
    "\n",
    "# Demo config generation\n",
    "print(\"\\nConfiguration Generator\")\n",
    "print(\"=\" * 60)\n",
    "\n",
    "test_cases = [\n",
    "    {\"model_size\": \"7b\", \"vram_gb\": 16, \"method\": \"lora\"},\n",
    "    {\"model_size\": \"7b\", \"vram_gb\": 8, \"method\": \"qlora\"},\n",
    "    {\"model_size\": \"13b\", \"vram_gb\": 24, \"method\": \"lora\"},\n",
    "    {\"model_size\": \"70b\", \"vram_gb\": 48, \"method\": \"qlora\"},\n",
    "]\n",
    "\n",
    "for case in test_cases:\n",
    "    config = generate_training_config(**case)\n",
