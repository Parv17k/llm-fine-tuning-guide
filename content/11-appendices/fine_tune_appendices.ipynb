    "## 4. Model Comparison Tool"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import matplotlib.pyplot as plt\n",
    "import numpy as np\n",
    "\n",
    "# Model database\n",
    "MODELS = [\n",
    "    {\"name\": \"Phi-3 Mini\", \"params\": 3.8, \"vram_16bit\": 8, \"vram_4bit\": 3, \"context\": 128, \"score\": 75},\n",
    "    {\"name\": \"Llama-3.2-1B\", \"params\": 1, \"vram_16bit\": 2, \"vram_4bit\": 1, \"context\": 8, \"score\": 55},\n",
    "    {\"name\": \"Llama-3.2-3B\", \"params\": 3, \"vram_16bit\": 6, \"vram_4bit\": 2.5, \"context\": 8, \"score\": 70},\n",
    "    {\"name\": \"Mistral-7B\", \"params\": 7, \"vram_16bit\": 14, \"vram_4bit\": 4, \"context\": 32, \"score\": 80},\n",
    "    {\"name\": \"Llama-3.1-8B\", \"params\": 8, \"vram_16bit\": 16, \"vram_4bit\": 5, \"context\": 128, \"score\": 82},\n",
    "    {\"name\": \"Gemma-2-9B\", \"params\": 9, \"vram_16bit\": 18, \"vram_4bit\": 5, \"context\": 8, \"score\": 83},\n",
    "    {\"name\": \"Qwen2-14B\", \"params\": 14, \"vram_16bit\": 28, \"vram_4bit\": 8, \"context\": 128, \"score\": 85},\n",
    "    {\"name\": \"Command-R-35B\", \"params\": 35, \"vram_16bit\": 70, \"vram_4bit\": 20, \"context\": 128, \"score\": 88},\n",
    "    {\"name\": \"Llama-3.1-70B\", \"params\": 70, \"vram_16bit\": 140, \"vram_4bit\": 40, \"context\": 128, \"score\": 92},\n",
    "]\n",
    "\n",
    "def compare_models(vram_budget: float = 16, quantization: str = \"4-bit\") -> list:\n",
    "    \"\"\"Find models that fit VRAM budget.\"\"\"\n",
    "    vram_key = \"vram_4bit\" if quantization == \"4-bit\" else \"vram_16bit\"\n",
    "    \n",
    "    fitting = [m for m in MODELS if m[vram_key] <= vram_budget]\n",
    "    fitting.sort(key=lambda x: x[\"score\"], reverse=True)\n",
    "    \n",
    "    return fitting\n",
    "\n",
    "def plot_model_comparison():\n",
    "    \"\"\"Plot model comparison chart.\"\"\"\n",
    "    names = [m[\"name\"] for m in MODELS]\n",
    "    params = [m[\"params\"] for m in MODELS]\n",
    "    scores = [m[\"score\"] for m in MODELS]\n",
    "    vram_4bit = [m[\"vram_4bit\"] for m in MODELS]\n",
    "    \n",
    "    fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(14, 6))\n",
    "    \n",
    "    # Parameters vs Score\n",
    "    ax1.scatter(params, scores, s=100, alpha=0.7, c='#238636')\n",
    "    for i, name in enumerate(names):\n",
    "        ax1.annotate(name, (params[i], scores[i]), fontsize=8, ha='center')\n",
    "    ax1.set_xlabel('Parameters (B)')\n",
    "    ax1.set_ylabel('Performance Score')\n",
    "    ax1.set_title('Model Size vs Performance')\n",
    "    ax1.grid(True, alpha=0.3)\n",
    "    \n",
    "    # VRAM vs Score\n",
    "    ax2.scatter(vram_4bit, scores, s=100, alpha=0.7, c='#347d39')\n",
    "    for i, name in enumerate(names):\n",
    "        ax2.annotate(name, (vram_4bit[i], scores[i]), fontsize=8, ha='center')\n",
    "    ax2.set_xlabel('VRAM Required (4-bit, GB)')\n",
    "    ax2.set_ylabel('Performance Score')\n",
    "    ax2.set_title('VRAM vs Performance (4-bit Quantized)')\n",
    "    ax2.grid(True, alpha=0.3)\n",
    "    \n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "# Demo model comparison\n",
    "print(\"Model Comparison Tool\")\n",
    "print(\"=\" * 60)\n",
    "\n",
    "budgets = [4, 8, 16, 40]\n",
    "\n",
    "for budget in budgets:\n",
    "    print(f\"\\nVRAM Budget: {budget}GB (4-bit)\")\n",
    "    fitting = compare_models(vram_budget=budget)\n",
    "    if fitting:\n",
    "        best = fitting[0]\n",
    "        print(f\"  Best fit: {best['name']} (Score: {best['score']}, VRAM: {best['vram_4bit']}GB)\")\n",
    "        print(f\"  All fitting: {', '.join([m['name'] for m in fitting])}\")\n",
    "    else:\n",
    "        print(\"  No models fit this budget\")\n",
    "\n",
    "# Plot comparison\n",
    "plot_model_comparison()"
   ]
  },
