    "## 2. Troubleshooting Decision Tree"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Troubleshooting knowledge base\n",
    "TROUBLESHOOTING_KB = {\n",
    "    \"oom\": {\n",
    "        \"error_patterns\": [\"out of memory\", \"oom\", \"cuda memory\"],\n",
    "        \"solutions\": [\n",
    "            \"Reduce batch size (try half current value)\",\n",
    "            \"Enable gradient accumulation to maintain effective batch\",\n",
    "            \"Enable gradient checkpointing (saves ~40% memory)\",\n",
    "            \"Use QLoRA 4-bit quantization\",\n",
    "            \"Use ZeRO offload for multi-GPU\",\n",
    "        ],\n",
    "        \"priority\": \"critical\",\n",
    "    },\n",
    "    \"nan_loss\": {\n",
    "        \"error_patterns\": [\"nan\", \"loss: nan\", \"numerical error\"],\n",
    \"solutions\": [\n",
    "            \"Reduce learning rate (try 10x lower)\",\n",
    "            \"Add gradient clipping (max_grad_norm: 1.0)\",\n",
    "            \"Add warmup steps (warmup_steps: 100)\",\n",
    "            \"Check training data for corruption\",\n",
    "            \"Use stable attention (sdpa backend)\",\n",
    "        ],\n",
    "        \"priority\": \"high\",\n",
    "    },\n",
    "    \"tokenizer_error\": {\n",
    "        \"error_patterns\": [\"tokenizer\", \"vocab\", \"special token\"],\n",
    "        \"solutions\": [\n",
    "            \"Load tokenizer from same checkpoint as model\",\n",
    "            \"Clear Hugging Face cache (~/.cache/huggingface)\",\n",
    "            \"Check model type matches tokenizer type\",\n",
    "        ],\n",
    "        \"priority\": \"medium\",\n",
    "    },\n",
    "    \"slow_training\": {\n",
    "        \"error_patterns\": [\"slow\", \"taking long\", \"bottleneck\"],\n",
    "        \"solutions\": [\n",
    "            \"Increase dataloader_num_workers (try 4-8)\",\n",
    "            \"Enable bf16/fp16 mixed precision\",\n",
    "            \"Use gradient accumulation instead of large batch\",\n",
    "            \"Check disk I/O (use SSD for data)\",\n",
    "        ],\n",
    "        \"priority\": \"low\",\n",
    "    },\n",
    "    \"overfitting\": {\n",
    "        \"error_patterns\": [\"overfit\", \"validation loss increasing\", \"poor generalization\"],\n",
    "        \"solutions\": [\n",
    "            \"Reduce number of epochs\",\n",
    "            \"Use early stopping\",\n",
    "            \"Increase dropout (try 0.1)\",\n",
    "            \"Add more training data\",\n",
    "            \"Use data augmentation\",\n",
    "        ],\n",
    "        \"priority\": \"medium\",\n",
    "    },\n",
    "}\n",
    "\n",
    "def diagnose_error(error_message: str) -> dict:\n",
    "    \"\"\"Diagnose error and suggest solutions.\"\"\"\n",
    "    error_lower = error_message.lower()\n",
    "    \n",
    "    for issue_id, issue_data in TROUBLESHOOTING_KB.items():\n",
    "        for pattern in issue_data[\"error_patterns\"]:\n",
    "            if pattern in error_lower:\n",
    "                return {\n",
    "                    \"issue\": issue_id,\n",
    "                    \"priority\": issue_data[\"priority\"],\n",
    "                    \"solutions\": issue_data[\"solutions\"],\n",
    "                }\n",
    "    \n",
    "    return {\"issue\": \"unknown\", \"priority\": \"unknown\", \"solutions\": [\"Check documentation\", \"Search GitHub issues\"]}\n",
    "\n",
    "# Demo troubleshooting\n",
    "print(\"Troubleshooting Demo\")\n",
    "print(\"=\" * 60)\n",
    "\n",
    "test_errors = [\n",
    "    \"CUDA out of memory: tried to allocate 2GB\",\n",
    "    \"Loss became nan at step 142\",\n",
    "    \"Tokenizer mismatch error\",\n",
    "    \"Training is very slow\",\n",
    "]\n",
    "\n",
    "for error in test_errors:\n",
    "    print(f\"\\nError: {error}\")\n",
    "    diagnosis = diagnose_error(error)\n",
    "    print(f\"Issue: {diagnosis['issue']} (Priority: {diagnosis['priority']})\")\n",
    "    print(\"Suggested solutions:\")\n",
    "    for i, sol in enumerate(diagnosis[\"solutions\"], 1):\n",
    "        print(f\"  {i}. {sol}\")"
   ]
  },
