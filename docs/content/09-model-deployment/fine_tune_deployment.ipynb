   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Model Deployment\n",
    "\n",
    "Hands-on examples for Module 09, covering:\n",
    "\n",
    "1. LoRA adapter merging\n",
    "2. Model quantization (GGUF, AWQ)\n",
    "3. vLLM serving setup\n",
    "4. FastAPI wrapper\n",
    "5. Streaming responses"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Setup"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Install required packages\n",
    "# !pip install transformers peft torch fastapi uvicorn\n",
    "# !pip install vllm  # For vLLM serving\n",
    "# !pip install autoawq  # For AWQ quantization\n",
    "\n",
    "import torch\n",
    "import json\n",
    "import time\n",
    "from pathlib import Path\n",
    "\n",
    "print(f\"PyTorch version: {torch.__version__}\")\n",
    "print(f\"CUDA available: {torch.cuda.is_available()}\")\n",
    "if torch.cuda.is_available():\n",
    "    print(f\"GPU: {torch.cuda.get_device_name(0)}\")\n",
    "    print(f\"Available VRAM: {torch.cuda.get_device_properties(0).total_memory / 1e9:.2f} GB\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. LoRA Adapter Merging"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from transformers import AutoModelForCausalLM, AutoTokenizer\n",
    "from peft import PeftModel\n",
    "\n",
    "# Use a small model for demonstration\n",
    "model_name = \"TinyLlama/TinyLlama-1.1B-Chat-v1.0\"\n",
    "\n",
    "print(\"Loading base model...\")\n",
    "base_model = AutoModelForCausalLM.from_pretrained(\n",
    "    model_name,\n",
    "    torch_dtype=torch.float32,\n",
    "    device_map=\"auto\" if torch.cuda.is_available() else None,\n",
    ")\n",
    "\n",
    "tokenizer = AutoTokenizer.from_pretrained(model_name)\n",
    "tokenizer.pad_token = tokenizer.eos_token\n",
    "\n",
    "print(f\"Base model loaded: {sum(p.numel() for p in base_model.parameters()):,} parameters\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Simulate a trained LoRA adapter (in practice, load from your checkpoint)\n",
    "from peft import LoraConfig, get_peft_model\n",
    "\n",
    "# Create LoRA config (simulating a trained adapter)\n",
    "lora_config = LoraConfig(\n",
    "    r=16,\n",
    "    lora_alpha=32,\n",
    "    target_modules=[\"q_proj\", \"k_proj\", \"v_proj\", \"o_proj\"],\n",
    "    lora_dropout=0.05,\n",
    "    task_type=\"CAUSAL_LM\",\n",
    ")\n",
    "\n",
    "# Apply LoRA to simulate trained adapter\n",
    "lora_model = get_peft_model(base_model, lora_config)\n",
    "lora_model.print_trainable_parameters()\n",
    "\n",
    "# Save the \"trained\" adapter\n",
    "lora_model.save_pretrained(\"./temp-lora-adapter\")\n",
    "print(\"Adapter saved to ./temp-lora-adapter\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Now merge the adapter\n",
    "print(\"\\nLoading adapter for merging...\")\n",
    "\n",
    "# Reload base model\n",
    "base_model = AutoModelForCausalLM.from_pretrained(\n",
    "    model_name,\n",
    "    torch_dtype=torch.float32,\n",
    "    device_map=\"auto\" if torch.cuda.is_available() else None,\n",
    ")\n",
    "\n",
    "# Load adapter\n",
    "model = PeftModel.from_pretrained(base_model, \"./temp-lora-adapter\")\n",
    "\n",
    "# Merge\n",
    "print(\"Merging adapter into base model...\")\n",
    "merged_model = model.merge_and_unload()\n",
    "\n",
    "print(f\"\\nMerged model parameters: {sum(p.numel() for p in merged_model.parameters()):,}\")\n",
    "print(f\"Trainable after merge: {sum(p.numel() for p in merged_model.parameters() if p.requires_grad):,}\")\n",
    "\n",
    "# Save merged model\n",
    "merged_model.save_pretrained(\"./merged-model\")\n",
    "tokenizer.save_pretrained(\"./merged-model\")\n",
    "print(\"\\nMerged model saved to ./merged-model\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Model Quantization Demo"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Compare model sizes\n",
    "import os\n",
    "\n",
    "def get_model_size(path):\n",
    "    \"\"\"Get total size of model files.\"\"\"\n",
    "    total = 0\n",
    "    for root, dirs, files in os.walk(path):\n",
    "        for f in files:\n",
    "            if f.endswith(\".bin\") or f.endswith(\".safetensors\"):\n",
    "                total += os.path.getsize(os.path.join(root, f))\n",
    "    return total / 1e9  # GB\n",
    "\n",
    "# Get sizes\n",
    "original_size = get_model_size(f\"~/.cache/huggingface/hub/models--{model_name.replace('/', '--')}\")\n",
    "merged_size = get_model_size(\"./merged-model\")\n",
    "\n",
    "print(\"Model Size Comparison:\")\n",
    "print(\"=\" * 40)\n",
    "print(f\"Original (cached): ~{original_size:.2f} GB\")\n",
    "print(f\"Merged (saved):    ~{merged_size:.2f} GB\")\n",
    "\n",
    "# Simulated quantized sizes\n",
    "print(\"\\nEstimated Quantized Sizes:\")\n",
    "print(\"=\" * 40)\n",
    "print(f\"8-bit (50%):   ~{merged_size * 0.5:.2f} GB\")\n",
    "print(f\"4-bit (25%):   ~{merged_size * 0.25:.2f} GB\")\n",
    "print(f\"4-bit GGUF Q4_K_M: ~{merged_size * 0.28:.2f} GB\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# AWQ Quantization (if available)\n",
    "try:\n",
    "    from awq import AutoAWQForCausalLM\n",
    "    \n",
    "    print(\"\\nRunning AWQ 4-bit quantization...\")\n",
    "    \n",
    "    # Load and quantize\n",
    "    model_awq = AutoAWQForCausalLM.from_pretrained(\"./merged-model\")\n",
    "    model_awq.quantize(n_parallel=4, w_bit=4, q_group_size=128)\n",
    "    \n",
    "    # Save quantized model\n",
    "    model_awq.save_quantized(\"./merged-model-awq\")\n",
    "    print(\"AWQ quantized model saved to ./merged-model-awq\")\n",
    "    \n",
    "    awq_size = get_model_size(\"./merged-model-awq\")\n",
    "    print(f\"AWQ model size: {awq_size:.2f} GB\")\n",
    "    \n",
    "except ImportError:\n",
    "    print(\"\\nAWQ not installed. Install with: pip install autoawq\")\n",
    "except Exception as e:\n",
    "    print(f\"AWQ quantization error: {e}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. FastAPI Serving"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Create FastAPI server script\n",
    "server_code = '''\n",
    "from fastapi import FastAPI, HTTPException\n",
    "from pydantic import BaseModel\n",
    "from transformers import AutoModelForCausalLM, AutoTokenizer\n",
    "import torch\n",
    "import time\n",
    "\n",
    "app = FastAPI(title=\"LLM Inference API\")\n",
    "\n",
    "# Load model\n",
    "print(\"Loading model...\")\n",
    "model = AutoModelForCausalLM.from_pretrained(\n",
    "    \"./merged-model\",\n",
    "    torch_dtype=torch.float32,\n",
    "    device_map=\"auto\" if torch.cuda.is_available() else None,\n",
    ")\n",
    "tokenizer = AutoTokenizer.from_pretrained(\"./merged-model\")\n",
    "print(\"Model loaded!\")\n",
    "\n",
    "class GenerateRequest(BaseModel):\n",
    "    prompt: str\n",
    "    max_tokens: int = 100\n",
    "    temperature: float = 0.7\n",
    "    top_p: float = 0.9\n",
    "    stream: bool = False\n",
    "\n",
    "class GenerateResponse(BaseModel):\n",
    "    response: str\n",
    "    tokens_generated: int\n",
    "    latency_ms: float\n",
    "\n",
    "@app.get(\"/health\")\n",
    "async def health():\n",
    "    return {\"status\": \"healthy\"}\n",
    "\n",
    "@app.post(\"/generate\", response_model=GenerateResponse)\n",
    "async def generate(req: GenerateRequest):\n",
    "    start_time = time.time()\n",
    "    \n",
    "    try:\n",
    "        inputs = tokenizer(req.prompt, return_tensors=\"pt\")\n",
    "        if torch.cuda.is_available():\n",
    "            inputs = {k: v.cuda() for k, v in inputs.items()}\n",
    "        \n",
    "        with torch.no_grad():\n",
    "            outputs = model.generate(\n",
    "                **inputs,\n",
    "                max_new_tokens=req.max_tokens,\n",
    "                temperature=req.temperature,\n",
    "                do_sample=req.temperature > 0,\n",
    "                top_p=req.top_p,\n",
    "                pad_token_id=tokenizer.eos_token_id,\n",
    "            )\n",
    "        \n",
    "        response = tokenizer.decode(outputs[0], skip_special_tokens=True)\n",
    "        tokens_generated = outputs.shape[1] - inputs[\"input_ids\"].shape[1]\n",
    "        latency_ms = (time.time() - start_time) * 1000\n",
    "        \n",
    "        return GenerateResponse(\n",
    "            response=response,\n",
    "            tokens_generated=tokens_generated,\n",
    "            latency_ms=latency_ms,\n",
    "        )\n",
    "    except Exception as e:\n",
    "        raise HTTPException(status_code=500, detail=str(e))\n",
    "\n",
    "if __name__ == \"__main__\":\n",
    "    import uvicorn\n",
    "    uvicorn.run(app, host=\"0.0.0.0\", port=8000)\n",
    '''\n",
    "\n",
    "# Save server script\n",
    "with open(\"llm_server.py\", \"w\") as f:\n",
    "    f.write(server_code)\n",
    "\n",
    "print(\"FastAPI server script saved to llm_server.py\")\n",
    "print(\"\\nTo start the server:\")\n",
    "print(\"  python llm_server.py\")\n",
    "print(\"\\nOr with uvicorn:\")\n",
    "print(\"  uvicorn llm_server:app --host 0.0.0.0 --port 8000\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Test the model directly (without starting server)\n",
    "print(\"Testing model inference...\")\n",
    "\n",
    "# Load merged model\n",
    "test_model = AutoModelForCausalLM.from_pretrained(\n",
    "    \"./merged-model\",\n",
    "    torch_dtype=torch.float32,\n",
    "    device_map=\"auto\" if torch.cuda.is_available() else None,\n",
    ")\n",
    "test_tokenizer = AutoTokenizer.from_pretrained(\"./merged-model\")\n",
    "\n",
    "# Test prompts\n",
    "test_prompts = [\n",
    "    \"What is machine learning?\",\n",
    "    \"Explain quantum computing in simple terms\",\n",
    "    \"Write a haiku about coding\",\n",
    "]\n",
    "\n",
    "print(\"\\n\" + \"=\" * 60)\n",
    "for prompt in test_prompts:\n",
    "    inputs = test_tokenizer(prompt, return_tensors=\"pt\")\n",
    "    if torch.cuda.is_available():\n",
    "        inputs = {k: v.cuda() for k, v in inputs.items()}\n",
    "    \n",
    "    start = time.time()\n",
    "    with torch.no_grad():\n",
    "        outputs = test_model.generate(\n",
    "            **inputs,\n",
    "            max_new_tokens=50,\n",
    "            temperature=0.7,\n",
    "            do_sample=True,\n",
    "            top_p=0.9,\n",
    "        )\n",
    "    latency = time.time() - start\n",
    "    \n",
    "    response = test_tokenizer.decode(outputs[0], skip_special_tokens=True)\n",
    "    tokens_gen = outputs.shape[1] - inputs[\"input_ids\"].shape[1]\n",
    "    \n",
    "    print(f\"\\nPrompt: {prompt}\")\n",
    "    print(f\"Response: {response}\")\n",
    "    print(f\"Tokens: {tokens_gen} | Latency: {latency*1000:.0f}ms | Speed: {tokens_gen/latency:.1f} tok/s\")\n",
    "    print(\"-\" * 60)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Streaming Response Implementation"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Streaming generator for token-by-token output\n",
    "def generate_stream(model, tokenizer, prompt, max_tokens=100, temperature=0.7):\n",
    "    \"\"\"Generate tokens one at a time for streaming.\"\"\"\n",
    "    inputs = tokenizer(prompt, return_tensors=\"pt\")\n",
    "    if torch.cuda.is_available():\n",
    "        inputs = {k: v.cuda() for k, v in inputs.items()}\n",
    "    \n",
    "    generated = inputs[\"input_ids\"]\n",
    "    \n",
    "    for i in range(max_tokens):\n",
    "        outputs = model.generate(\n",
    "            **inputs,\n",
    "            max_new_tokens=1,\n",
    "            temperature=temperature,\n",
    "            do_sample=temperature > 0,\n",
    "            pad_token_id=tokenizer.eos_token_id,\n",
    "        )\n",
    "        \n",
    "        new_token = outputs[0, -1].item()\n",
    "        token_text = tokenizer.decode([new_token])\n",
    "        \n",
    "        yield {\n",
    "            \"token\": token_text,\n",
    "            \"token_id\": new_token,\n",
    "            \"step\": i + 1,\n",
    "        }\n",
    "        \n",
    "        # Stop if EOS\n",
    "        if new_token == tokenizer.eos_token_id:\n",
    "            break\n",
    "        \n",
    "        # Append for next iteration\n",
    "        generated = torch.cat([generated, outputs[:, -1:]], dim=1)\n",
    "        inputs = {\"input_ids\": generated}\n",
    "\n",
    "# Demo streaming\n",
    "print(\"Streaming generation demo:\")\n",
    "print(\"=\" * 60)\n",
    "\n",
    "stream_output = \"\"\n",
    "for token_info in generate_stream(test_model, test_tokenizer, \"Write a short story about AI:\", max_tokens=30):\n",
    "    stream_output += token_info[\"token\"]\n",
    "    print(f\"Step {token_info['step']:2d}: '{token_info['token']}'\")\n",
    "\n",
    "print(\"\\n\" + \"=\" * 60)\n",
    "print(f\"Complete output: {stream_output}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. vLLM Setup Script"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Create vLLM startup script\n",
    "vllm_script = '''\n",
    "#!/bin/bash\n",
    "# vLLM High-Throughput Serving\n",
    "\n",
    "MODEL_PATH=\"./merged-model\"\n",
    "HOST=\"0.0.0.0\"\n",
    "PORT=8000\n",
    "\n",
    "# Start vLLM API server\n",
    "python -m vllm.entrypoints.api_server \\\\\n",
    "    --model $MODEL_PATH \\\\\n",
    "    --host $HOST \\\\\n",
    "    --port $PORT \\\\\n",
    "    --tensor-parallel-size 1 \\\\\n",
    "    --max-num-seqs 256 \\\\\n",
    "    --gpu-memory-utilization 0.9 \\\\\n",
    "    --max-num-batched-tokens 8192\n",
    "\n",
    "# Test the endpoint\n",
    "# curl http://localhost:8000/generate \\\\\n",
    "#   -d '{\"prompt\": \"Hello, my name is\", \"max_tokens\": 50}'\n",
    "'''\n",
    "\n",
    "with open(\"start_vllm.sh\", \"w\") as f:\n",
    "    f.write(vllm_script)\n",
    "\n",
    "print(\"vLLM startup script saved to start_vllm.sh\")\n",
    "print(\"Make executable: chmod +x start_vllm.sh\")\n",
    "print(\"Run: ./start_vllm.sh\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
